{
    "name":"YSBlocker",
    "version":"1.1.0",
    "manifest_version":3,
    "description":"YouTube Shortsと指定サイトの利用時間を猫オーバーレイで制限する個人用Chrome拡張機能",
    "icons":{
        "128":"icons/image1.png"
    },
    "permissions":[
        "storage",
        "tabs"
    ],
    "host_permissions":[
        "<all_urls>"
    ],
    "background":{
        "service_worker":"js/site_timer_background.js"
    },
    "options_page":"options.html",
    "action":{
        "default_title":"YSBlocker",
        "default_popup":"popup.html"
    },
    "content_scripts":[
        {
            "matches":[
                "<all_urls>"
            ],
            "js":[
                "js/site_blocker_content.js"
            ],
            "run_at":"document_idle"
        }
    ],
    "web_accessible_resources":[
        {
            "resources":[
                "assets/12621388_1080_1920_30fps.mp4",
                "assets/15369422_1080_1920_60fps.mp4",
                "assets/cat-gatekeeper.webm"
            ],
            "matches":[
                "<all_urls>"
            ]
        }
    ]
}
