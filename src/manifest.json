{
    "name":"YSBlocker",
    "version":"1.0.0",
    "manifest_version":3,
    "description":"個人ブラウザ設定",
    "icons":{
        "128":"icons/image1.png"
    },
    "content_scripts":[{
        "matches":[
            "https://www.youtube.com/*",
            "https://m.youtube.com/*"
        ],
        "js":[
            "js/short_blocker.js"
        ],
        "run_at":"document_idle"
    }]
}
